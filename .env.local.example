# ============================================================
# Starter Kit v3 — .env.local.example
# Copy to .env.local and fill in. Uses Q4-2025 Supabase naming.
# (NOT the legacy anon/service_role names.)
# ============================================================

# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Publishable (browser-safe) key — replaces the legacy ANON key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Secret (server-only) key — replaces the legacy SERVICE_ROLE key
# NEVER expose this to the client.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# Public site URL (used by Supabase server client for OAuth redirect resolution)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Verify against code before trusting these names: ─────────
#   grep -rn "process.env" src/ | grep -i supabase
# The example must match what the code actually reads (Run 001 L9).
